<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Wooden Chess</title>
<link rel="stylesheet" href="https://unpkg.com/@chrisoakman/chessboardjs@1.0.0/dist/chessboard-1.0.0.min.css">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@600&display=swap');
  body {
    background: #2b2b2b;
    display: flex; flex-direction: column; justify-content: center; align-items: center;
    min-height: 100vh; font-family: 'Poppins', sans-serif; color: #ecf0f1; margin: 0;
  }
  h1 { color: #e0c097; margin-bottom: 10px; letter-spacing: 2px; }
  #info { font-size: 18px; margin-bottom: 15px; font-weight: 600; color: #e0c097; }
  #board { 
    width: 90vmin; max-width: 500px; 
    box-shadow: 0 20px 50px rgba(0,0,0,0.7); 
    border: 12px solid #3e2f1c;
    border-radius: 4px;
  }

  /* BOARD COLORS TO MATCH YOUR PHOTO */
  .white-1e1d7 { 
    background-color: #e8dcc6; /* light maple */
  }
  .black-3c85d { 
    background-color: #8b5a2b; /* dark walnut */
  }

  /* PIECE STYLE */
  .piece-417db { transition: transform 0.15s ease; }
  .piece-417db:hover { transform: scale(1.05); }

  .highlight { box-shadow: inset 0 0 0 4px rgba(255, 215, 0, 0.8); }
  .check { box-shadow: inset 0 0 0 4px rgba(200, 0, 0, 0.8); }

  #controls { margin-top: 15px; display: flex; gap: 10px; }
  button {
    padding: 10px 20px; background: #8b5a2b; color: #e8dcc6; border: none;
    border-radius: 6px; font-weight: 600; cursor: pointer; font-size: 15px;
    border: 2px solid #3e2f1c;
  }
  button:hover { background: #a66e33; }
</style>
</head>
<body>
<h1>WOODEN CHESS</h1>
<div id="info">White to move</div>
<div id="board"></div>
<div id="controls">
  <button onclick="resetGame()">New Game</button>
  <button onclick="board.flip()">Flip</button>
  <button onclick="undoMove()">Undo</button>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://unpkg.com/@chrisoakman/chessboardjs@1.0.0/dist/chessboard-1.0.0.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/chess.js/0.10.3/chess.min.js"></script>
<script>
let board = null;
let game = new Chess();
let $board = $('#board');

/* USE WOODEN PIECE IMAGES TO MATCH YOUR PHOTO */
const config = {
  draggable: true,
  position: 'start',
  pieceTheme: 'https://chessboardjs.com/img/chesspieces/wikipedia/{piece}.png',
  onDragStart: onDragStart,
  onDrop: onDrop,
  onMouseoverSquare: onMouseoverSquare,
  onMouseoutSquare: onMouseoutSquare,
  onSnapEnd: onSnapEnd
};

function removeHighlights() {
  $board.find('.square-55d63').removeClass('highlight check');
}

function onDragStart (source, piece) {
  if (game.game_over()) return false;
  if (piece.search(new RegExp('^' + game.turn())) === -1) return false;
}

function onDrop (source, target) {
  removeHighlights();
  let move = game.move({ from: source, to: target, promotion: 'q' });
  if (move === null) return 'snapback';
  updateStatus();
}

function onMouseoverSquare(square) {
  let moves = game.moves({ square: square, verbose: true });
  if (moves.length === 0) return;
  $(`[data-square="${square}"]`).addClass('highlight');
  for (let i = 0; i < moves.length; i++) {
    $(`[data-square="${moves[i].to}"]`).addClass('highlight');
  }
}

function onMouseoutSquare() { removeHighlights(); }
function onSnapEnd () { board.position(game.fen()); }

function updateStatus() {
  let status = '';
  let moveColor = game.turn() === 'w' ? 'White' : 'Black';

  if (game.in_checkmate()) {
    status = 'Checkmate! ' + (moveColor === 'White' ? 'Black' : 'White') + ' wins';
  } else if (game.in_draw()) {
    status = 'Draw';
  } else if (game.in_check()) {
    status = moveColor + ' is in check';
    let kingPos = '';
    game.board().forEach((row, r) => row.forEach((p, c) => {
      if(p && p.type === 'k' && p.color === game.turn()) kingPos = 'abcdefgh'[c] + (8-r);
    }));
    $(`[data-square="${kingPos}"]`).addClass('check');
  } else {
    status = moveColor + ' to move';
  }
  $('#info').html(status);
}

function resetGame() { game.reset(); board.start(); updateStatus(); }
function undoMove() { game.undo(); board.position(game.fen()); updateStatus(); }

board = Chessboard('board', config);
updateStatus();
</script>
</body>
</html>
